{
  "name": "@tbh/inventory-app",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "concurrently -n vite,tsc -c cyan,yellow \"vite\" \"tsc --noEmit --watch --preserveWatchOutput\"",
    "build": "tsc && vite build",
    "lint": "eslint src",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "@tbh/application": "workspace:*",
    "@tbh/domain": "workspace:*",
    "@tbh/infrastructure": "workspace:*",
    "@tbh/types": "workspace:*",
    "@tbh/ui": "workspace:*",
    "@zxing/browser": "^0.1.5",
    "@zxing/library": "^0.21.3",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.22.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@tbh/config": "workspace:*",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^9.0.0",
    "typescript": "^5.5.0",
    "concurrently": "^9.0.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^0.21.0"
  }
